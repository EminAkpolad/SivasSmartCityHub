@model List<SmartCityHub.Models.Duyuru>

@{
    ViewData["Title"] = "Sivas Smart City - Kampüs Duyuruları";

    bool isAdmin = true; 
}

<div class="container mt-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-dark">
                <i class="bi bi-megaphone-fill text-danger"></i> Kampüs & Şehir Duyuruları
            </h2>
            <p class="text-muted">Cumhuriyet Üniversitesi Güncel Duyurular Yemekhane,Otobüs Saatleri ve Eğitimsel Bilgilendirmeler</p>
        </div>
        
        @if (isAdmin)
        {
            <div class="col-md-4 text-end">
                <a href="/Duyuru/Ekle" class="btn btn-danger btn-lg shadow-sm">
                    <i class="bi bi-plus-circle"></i> Yeni Duyuru Yayınla
                </a>
            </div>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-light border">
            <h4 class="text-secondary">Şu an aktif bir duyuru bulunmuyor!</h4>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var duyuru in Model)
            {
                <div class="col-12 mb-3">
                    <div class="card border-0 shadow-sm duyuru-card">
                        <div class="card-body p-4 d-flex flex-column flex-md-row gap-4 align-items-center">
                            
                            <div class="duyuru-img-wrapper flex-shrink-0">
                                <img src="@(string.IsNullOrEmpty(duyuru.ResimUrl) ? "/images/default-duyuru.jpg" : duyuru.ResimUrl)" 
                                     alt="Duyuru Görseli" class="rounded object-fit-cover">
                            </div>

                            <div class="flex-grow-1 w-100">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h4 class="fw-bold text-dark mb-0">@duyuru.Baslik</h4>
                                    <div>
                                        @if (duyuru.onem == SmartCityHub.Models.Duyuru.OnemSeviyesi.Acil)
                                        {
                                            <span class="badge bg-danger me-1">Acil</span>
                                        }
                                        else if (duyuru.onem == SmartCityHub.Models.Duyuru.OnemSeviyesi.Uyari)
                                        {
                                            <span class="badge bg-warning text-dark me-1">Uyarı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark me-1">ℹBilgi</span>
                                        }

                                        <span class="badge bg-secondary">
                                            <i class="bi bi-calendar3"></i> @duyuru.OlusturmaTarihi.ToString("dd.MM.yyyy")
                                        </span>
                                    </div>
                                </div>
                                
                                <p class="text-muted text-truncate-2 mb-3">@duyuru.Icerik</p>
                                
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <div>
                                        <span class="badge bg-primary text-wrap">@duyuru.kategori</span>
                                    </div>

                                    <div class="d-flex gap-2 align-items-center">
                                        <a href="/Duyuru/Detay/@duyuru.Id" class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-eye"></i> İncele
                                        </a>

                                        @if (isAdmin)
                                        {
                                            <a href="/Duyuru/Guncelle/@duyuru.Id" class="btn btn-outline-warning btn-sm">
                                                <i class="bi bi-pencil"></i> Düzenle
                                            </a>

                                            <form asp-controller="Duyuru" asp-action="Sil" asp-route-id="@duyuru.Id" method="post" 
                                                  onsubmit="return confirm('Bu duyuruyu kaldırmak istediğine emin misin?');" class="m-0">
                                                <button type="submit" class="btn btn-link text-danger p-0 text-decoration-none ms-2">
                                                    <i class="bi bi-trash3-fill"></i> Kaldır
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .duyuru-card {
        transition: all 0.3s ease;
        border-left: 5px solid #dc3545 !important;
        background-color: #ffffff;
    }
    .duyuru-card:hover {
        transform: translateX(5px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
    }
    .duyuru-img-wrapper img {
        width: 150px;
        height: 100px;
        border: 1px solid #dee2e6;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    @@media (max-width: 768px) {
        .duyuru-card .card-body {
            text-align: center;
        }
        .duyuru-img-wrapper img {
            width: 100%;
            height: 180px;
        }
        .duyuru-card .d-flex {
            flex-direction: column !important;
        }
    }
</style>