@model List<SmartCityHub.Models.Duyuru>

@{
    ViewData["Title"] = "Duyurular";
    bool isAdmin = true; 
}

<div class="container my-5">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-12 col-md-8 text-center text-md-start">
            <h2 class="fw-bold mb-1">Kampüs Duyuruları</h2>
            <p class="text-muted mb-0">Sivas Cumhuriyet Üniversitesi gelişmeler.</p>
        </div>
        @if (isAdmin)
        {
            <div class="col-12 col-md-4 text-center text-md-end">
                <a href="/Duyuru/Ekle" class="btn btn-danger btn-lg w-100 w-md-auto shadow-sm">
                    <i class="bi bi-plus-lg"></i> Yeni Duyuru Ekle
                </a>
            </div>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-secondary text-center p-5 rounded-3" role="alert">
            <h4 class="alert-heading fw-bold">Aktif Duyuru Yok!</h4>
            <p class="mb-0 text-muted">Şu an veritabanında listelenecek hiçbir duyuru kaydı bulunamadı.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var duyuru in Model)
            {
                <div class="col-12">
                    <div class="card shadow-sm h-100 border-start border-danger border-4">
                        <div class="card-body p-4">
                            <div class="row align-items-center g-3">
                                
                                <div class="col-12 col-md-3 text-center">
                                    <img src="@(string.IsNullOrEmpty(duyuru.ResimUrl) ? "https://via.placeholder.com/150x100?text=Duyuru" : duyuru.ResimUrl)" 
                                         alt="Afiş" class="img-fluid rounded border w-100" style="max-height: 140px; object-fit: cover;">
                                </div>

                                <div class="col-12 col-md-9">
                                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                                        <h4 class="fw-bold text-dark mb-0 text-center text-md-start w-100 w-md-auto">@duyuru.Baslik</h4>
                                        <div class="d-flex gap-1 ms-auto ms-md-0">
                                            @if (duyuru.onem == SmartCityHub.Models.Duyuru.OnemSeviyesi.Acil)
                                            {
                                                <span class="badge bg-danger">Acil</span>
                                            }
                                            else if (duyuru.onem == SmartCityHub.Models.Duyuru.OnemSeviyesi.Uyari)
                                            {
                                                <span class="badge bg-warning text-dark">Uyarı</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark">ℹBilgi</span>
                                            }
                                            <span class="badge bg-light text-dark border">@duyuru.OlusturmaTarihi.ToString("dd.MM.yyyy")</span>
                                        </div>
                                    </div>

                                    <p class="text-muted small mb-3 text-center text-md-start">@duyuru.Icerik</p>

                                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 pt-2 border-top">
                                        <span class="badge bg-primary">@duyuru.kategori</span>
                                        
                                        <div class="d-flex gap-2 w-100 w-sm-auto justify-content-end">
                                            <a href="/Duyuru/Detay/@duyuru.Id" class="btn btn-outline-secondary btn-sm">İncele</a>
                                            
                                            @if (isAdmin)
                                            {
                                                <a href="/Duyuru/Guncelle/@duyuru.Id" class="btn btn-outline-warning btn-sm">Düzenle</a>
                                                
                                                <form asp-controller="Duyuru" asp-action="Sil" asp-route-id="@duyuru.Id" method="post" 
                                                      onsubmit="return confirm('Silinsin mi kanka?');" class="d-inline m-0">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Kaldır</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>