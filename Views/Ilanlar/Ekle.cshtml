@model SmartCityHub.Models.Ilan

@{
    ViewData["Title"] = "Yeni İlan Ekle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Sivas Smart City - Yeni İlan Formu</h4>
                </div>
                <div class="card-body p-4">
                    @* KRİTİK NOKTA: enctype="multipart/form-data" EKLENDİ *@
                    <form asp-action="Ekle" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label asp-for="Baslik" class="form-label font-weight-bold">İlan Başlığı</label>
                            <input asp-for="Baslik" class="form-control" placeholder="Örn: Sivas Merkez Satılık Kitap" />
                            <span asp-validation-for="Baslik" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Aciklama" class="form-label">İlan Açıklaması</label>
                            <textarea asp-for="Aciklama" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Aciklama" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Fiyat" class="form-label">Fiyat (TL)</label>
                                <input asp-for="Fiyat" type="number" class="form-control" />
                                <span asp-validation-for="Fiyat" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">İlan Resmi Seç</label>
                                @* name="resimDosyasi" Controller'daki isimle aynı olmalı *@
                                <input type="file" name="resimDosyasi" class="form-control" accept="image/*" />
                            </div>
                        </div>

                        @* Eski ResimUrl inputu varsa onu sildik, çünkü yolu biz oluşturuyoruz *@

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg">İlanı Yayınla</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}